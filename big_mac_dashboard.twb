    <dashboard enable-sort-zone-taborder='true' name='Inferential Statistics Visualization'>
      <style />
      <size maxheight='600' maxwidth='1920' minheight='560' minwidth='420' sizing-mode='range' />
      <zones>
        <zone h='100000' id='4' type-v2='layout-basic' w='100000' x='0' y='0'>
