      <column caption='PPP' datatype='real' name='[Calculation_35747336731623424]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[local_price] / [dollar_price]' />
      </column>
      <column caption='PPP_Gap' datatype='real' name='[Calculation_35747336735760386]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[dollar_ex] - [Calculation_35747336731623424]' />
      </column>
      <column caption='USD_raw_Kategori' datatype='string' name='[Calculation_35747336753299459]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [USD_raw] &lt; -0.1 THEN &quot;Undervalued&quot;&#13;&#10;ELSEIF [USD_raw] &lt;= 0.1 THEN &quot;Fair&quot;&#13;&#10;ELSE &quot;Overvalued&quot;&#13;&#10;END' />
      </column>
